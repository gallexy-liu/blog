---
import { formatDate, type BlogPost } from "@/lib/posts";
import { pathWithBase } from "@/config/site";

type Props = {
  posts: BlogPost[];
};

const { posts } = Astro.props;
---

<div class="post-list">
  {posts.map((post) => (
    <article class="post-card">
      <a class="post-card-link" href={pathWithBase(`/posts/${post.slug}`)}>
        <div>
          <p class="post-meta">
            <span>{post.sectionName}</span>
            <time datetime={post.date}>{formatDate(post.date)}</time>
          </p>
          <h2>{post.title}</h2>
          <p>{post.description}</p>
        </div>
        {post.tags?.length ? (
          <ul class="tag-list" aria-label={`${post.title} 的标签`}>
            {post.tags.map((tag) => <li>{tag}</li>)}
          </ul>
        ) : null}
      </a>
    </article>
  ))}
</div>
