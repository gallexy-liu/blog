---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteSidebar from "@/components/SiteSidebar.astro";
import PostList from "@/components/PostList.astro";
import { site, pathWithBase } from "@/config/site";
import { getAllPosts } from "@/lib/posts";

const posts = getAllPosts();
---

<BaseLayout>
  <main class="shell">
    <SiteSidebar />

    <section class="content">
      <header class="page-header">
        <p class="eyebrow">Personal Blog</p>
        <h1>{site.title}</h1>
        <p>{site.description}</p>
      </header>

      <section class="section-band" aria-labelledby="sections-title">
        <div class="section-title-row">
          <h2 id="sections-title">板块</h2>
          <span>{site.sections.length} 个方向</span>
        </div>
        <div class="section-grid">
          {site.sections.map((section) => (
            <a class="section-card" href={pathWithBase(`/sections/${section.id}`)}>
              <span>{section.name}</span>
              <p>{section.description}</p>
            </a>
          ))}
        </div>
      </section>

      <section class="image-strip" aria-label="精选图片">
        {site.featuredImages.map((image) => (
          <figure>
            <img src={pathWithBase(image.src)} alt={image.alt} loading="lazy" />
            <figcaption>{image.title}</figcaption>
          </figure>
        ))}
      </section>

      <section aria-labelledby="latest-title">
        <div class="section-title-row">
          <h2 id="latest-title">最新文章</h2>
          <span>{posts.length} 篇</span>
        </div>
        <PostList posts={posts} />
      </section>
    </section>
  </main>
</BaseLayout>
