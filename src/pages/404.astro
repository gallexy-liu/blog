---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { pathWithBase } from "@/config/site";
---

<BaseLayout title="页面没有找到" description="请求的页面不存在。">
  <main class="not-found">
    <p class="eyebrow">404</p>
    <h1>页面没有找到</h1>
    <p>可能是链接写错了，或者这篇文章还在路上。</p>
    <a href={pathWithBase("/")}>回到首页</a>
  </main>
</BaseLayout>
